# .env.example — safe to commit, no real values
# Copy to .env and fill in your actual values (never commit .env)

# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key-here

# Backend port (default: 8080 for Cloud Shell Web Preview)
PORT=8080

# development = hot reload | production = stable server (Cloud Shell, Docker, Cloud Run)
ENV=development

# Comma-separated frontend origins for CORS (default: * for hackathon demo)
# CORS_ORIGINS=https://your-username.github.io,http://localhost:5500

# Optional: pre-configure GitHub Pages client-side mode via Actions secret API_BASE
# API_BASE=https://8080-cs-xxxx.cs.us-central1.cloudshell.dev
